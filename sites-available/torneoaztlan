server {
    if ($host = www.torneoaztlan.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    if ($host = torneoaztlan.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    listen [::]:80;

    server_name
        torneoaztlan.com
        www.torneoaztlan.com
        torneoaztlan.cloud
        www.torneoaztlan.cloud;

    return 301 https://torneoaztlan.com$request_uri;




}

server {

    listen 443 ssl;
    listen [::]:443 ssl;

    server_name
        torneoaztlan.com
        www.torneoaztlan.com
        torneoaztlan.cloud
        www.torneoaztlan.cloud;

    access_log /var/log/nginx/aztlan_access.log;
    error_log /var/log/nginx/aztlan_error.log;

    # SSL (.com)
    ssl_certificate /etc/letsencrypt/live/torneoaztlan.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/torneoaztlan.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Redirige todo lo que NO sea .com al .com
    if ($host != "torneoaztlan.com") {
        return 301 https://torneoaztlan.com$request_uri;
    }

    location /api/ {
        proxy_pass http://76.13.126.149:5000/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /comprobantes/ {
        alias /root/aztlan2026/aztlan-2026-api/uploads/comprobantes/;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;

        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_cache_bypass $http_upgrade;
    }


}
